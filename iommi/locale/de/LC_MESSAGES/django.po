#: templates/iommi/query/advanced.html:8
#: templates/iommi/query/daisyui/advanced.html:8
#: templates/iommi/query/form_toggle_script.html:48
msgid "Show help"
msgstr "Hilfe einblenden"

#: templates/iommi/query/advanced.html:13
#: templates/iommi/query/daisyui/advanced.html:13
msgid "Available fields"
msgstr "Verfügbare Felder"

#: templates/iommi/query/advanced.html:21
#: templates/iommi/query/daisyui/advanced.html:21
msgid "Queries"
msgstr "Datenabfragen"

#: templates/iommi/query/advanced.html:23
#: templates/iommi/query/daisyui/advanced.html:23
msgid "Search for an exact value: <code>field_name=value</code>"
msgstr "Suche nach exakter Wertangabe: <code>feld_name=wert</code>"

#: templates/iommi/query/advanced.html:24
#: templates/iommi/query/daisyui/advanced.html:24
msgid ""
"Search for an exact value containing space: <code>field_name=\"value with "
"space\"</code>"
msgstr ""
"Suche nach exakter Wertangabe mit Leerzeichen: <code>feld_name=\"wert mit "
"leerzeichen\"</code>"

#: templates/iommi/query/advanced.html:25
#: templates/iommi/query/daisyui/advanced.html:25
msgid "Containing a text: <code>field_name:val</code>"
msgstr "Suche nach Wert, der Zeichenfolge enthält: <code>feld_name=wer</code>"

#: templates/iommi/query/advanced.html:26
#: templates/iommi/query/daisyui/advanced.html:26
msgid "Exclude a value: <code>field_name!=value</code>"
msgstr "Suche, die einen Wert ausschließt: <code>feld_name!=wert</code>"

#: templates/iommi/query/advanced.html:27
#: templates/iommi/query/daisyui/advanced.html:27
msgid ""
"You can also use <code>&lt;</code>, <code>&gt;</code>, <code>&lt;=</code> "
"and <code>&gt;=</code> to find ranges of values: <code>field_name&lt;10</"
"code>"
msgstr ""
"Du kannst außerdem <code>&lt;</code>, <code>&gt;</code>, <code>&lt;=</code> "
"und <code>&gt;=</code> verwenden, um Zahlenbereiche von Werten zu finden: "
"<code>field_name&lt;10</code>"

#: templates/iommi/query/advanced.html:28
#: templates/iommi/query/daisyui/advanced.html:28
msgid ""
"To search for dates, use ISO8601 format: <code>field_name>1969-07-20</code>"
msgstr ""
"Nutze das ISO8601-Format um nach Datumsangaben zu suchen: "
"<code>field_name>1969-07-20</code>"

#: templates/iommi/query/advanced.html:29
#: templates/iommi/query/daisyui/advanced.html:29
msgid ""
"You can filter for relative dates: <code>field_name < \"10 days ago\"</"
"code>. Supported fields are <code>days</code>, <code>months</code>, "
"<code>years</code>, <code>quarters</code> and <code>weekdays</code>. They "
"can be negative and abbreviated from <code>\"10 days ago\"</code> to "
"<code>\"-10d\"</code>."
msgstr ""
"Du kannst nach Zeitpunkten relativ zum heutigen Tag suchen: <code>feld_name "
"< \"10 days ago\"</code>. Unterstützte Zeitspannen sind Tage (<code>days</"
"code>), Monate (<code>months</code>), Jahre (<code>years</code>), Quartale "
"(<code>quarters</code>) und Wochentage (<code>weekdays</code>). Die Angaben "
"können auch negativ sein und abgekürzt werden; so wird aus <code>\"10 days "
"ago\"</code> beispielsweise <code>\"-10d\"</code>."

#: templates/iommi/query/form_toggle_script.html:17
